# Clone Hero Playlist Downloader — production env
# No se necesitan credenciales para playlists públicas de Spotify o Apple Music.

# Ajustar si necesitas cambiar la sensibilidad del matching (0-100)
FUZZY_MATCH_THRESHOLD=70
MAX_RESULTS_PER_SONG=5

# Delays para evitar rate-limiting (segundos)
ENCHOR_RATE_LIMIT_DELAY=0.5
RHYTHMVERSE_RATE_LIMIT_DELAY=1.0

# Apple Music privada: requiere Apple Developer account ($99/año) — dejar vacío para playlists públicas
APPLE_MUSIC_DEVELOPER_TOKEN=
